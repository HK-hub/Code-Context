# VitePress Environment Configuration
# Copy this file to .env and customize for your environment

# Base URL for deployment
# GitHub Pages: /repo-name/ (e.g., /HContext/)
# Vercel: / (root path)
# Local development: / (or leave unset)
BASE_URL=/

# GitHub Pages specific (set by GitHub Actions automatically)
# GITHUB_PAGES=true
# GITHUB_REPOSITORY=HK-hub/HContext

# Vercel specific (set by Vercel automatically)
# VERCEL=1

# Future phases (Phase 8: Deployment & CI/CD)
# Uncomment when ready for deployment
# GITHUB_TOKEN=your_github_token_here
# VERCEL_TOKEN=your_vercel_token_here